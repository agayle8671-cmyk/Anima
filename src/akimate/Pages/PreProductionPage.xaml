<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="akimate.Pages.PreProductionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Gate Overlay -->
        <StackPanel x:Name="GateOverlay" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE72E;" FontSize="48" Opacity="0.4"/>
            <TextBlock Text="Phase Locked" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Complete Phase 1 (Conceptualization) first." Opacity="0.6" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer x:Name="ContentPanel" VerticalScrollBarVisibility="Auto" Padding="40,32,40,40" Visibility="Collapsed">
            <StackPanel Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

                <StackPanel Spacing="4">
                    <TextBlock Text="Phase 2: Pre-Production" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Storyboarding, character turnaround sheets, and 3D environmental layout."
                               FontSize="14" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Storyboard Section -->
                <TextBlock Text="Storyboard Generation" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="The Storyboard Agent creates image generation prompts for sequential panels from your script."
                           FontSize="13" Opacity="0.6" TextWrapping="Wrap"/>
                <Button x:Name="BtnGenerateStoryboard" Content="🎨 Generate Storyboards"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnGenerateStoryboard_Click"/>
                <TextBox x:Name="StoryboardStatus" IsReadOnly="True" AcceptsReturn="True"
                         MinHeight="120" TextWrapping="Wrap" PlaceholderText="Storyboard panel prompts appear here"/>

                <!-- Character Sheets Section -->
                <TextBlock Text="Character Turnaround Sheets" FontSize="18" FontWeight="SemiBold"/>
                <Button x:Name="BtnGenerateCharacterSheets" Content="🎨 Generate Character Sheets"
                        Click="BtnGenerateCharacterSheets_Click"/>
                <TextBox x:Name="CharacterSheetStatus" IsReadOnly="True" AcceptsReturn="True"
                         MinHeight="100" TextWrapping="Wrap" PlaceholderText="Character sheet prompts appear here"/>

                <!-- Lock Phase -->
                <InfoBar x:Name="PhaseInfoBar" IsOpen="False" IsClosable="True"
                         Severity="Success" Title="Pre-Production Complete"
                         Message="Proceed to Phase 3: Animatic &amp; Genga."/>
                <Button x:Name="BtnLockPreProduction" Content="🔒 Lock Pre-Production &amp; Proceed →"
                        Click="BtnLockPreProduction_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
