<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="akimate.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32,40,40">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <StackPanel Spacing="4">
                <TextBlock Text="Hardware Profile" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Auto-detected system specifications. akimate uses this to determine optimal AI model quantization and inference strategy."
                           FontSize="14" Opacity="0.7" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- GPU -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  CornerRadius="8" Padding="20" BorderThickness="1"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE7F7;" FontSize="28"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="GPU" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="GpuName" Text="Detecting..." FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="GpuVram" Text="" FontSize="12" Opacity="0.5"/>
                    <TextBlock x:Name="GpuDriver" Text="" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>

            <!-- CPU -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  CornerRadius="8" Padding="20" BorderThickness="1"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE950;" FontSize="28"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="CPU" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CpuName" Text="Detecting..." FontSize="13" Opacity="0.7"/>
                    <TextBlock x:Name="CpuCores" Text="" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>

            <!-- RAM -->
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  CornerRadius="8" Padding="20" BorderThickness="1"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xEDA2;" FontSize="28"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="System RAM" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="RamInfo" Text="Detecting..." FontSize="13" Opacity="0.7"/>
                </StackPanel>
            </Grid>

            <!-- Recommendation -->
            <InfoBar x:Name="RecommendationInfo" IsOpen="False" IsClosable="False"
                     Severity="Informational"
                     Title="Model Recommendation"/>

            <Button Content="Refresh" Click="BtnRefresh_Click"/>

        </StackPanel>
    </ScrollViewer>

</Page>
