<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="akimate.Pages.AnimaticPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Gate Overlay -->
        <StackPanel x:Name="GateOverlay" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE72E;" FontSize="48" Opacity="0.4"/>
            <TextBlock Text="Phase Locked" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Complete Phase 2 (Pre-Production) first." Opacity="0.6" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer x:Name="ContentPanel" VerticalScrollBarVisibility="Auto" Padding="40,32,40,40" Visibility="Collapsed">
            <StackPanel Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

                <StackPanel Spacing="4">
                    <TextBlock Text="Phase 3: Animatic &amp; Genga" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Timing, keyframe generation, and animation. The Animation Agent applies stepped curves and sakuga techniques."
                               FontSize="14" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Animation Parameters -->
                <TextBlock Text="Animation Parameters" FontSize="18" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="16" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6">
                        <TextBlock Text="Frame Rate" FontSize="14" FontWeight="SemiBold"/>
                        <ComboBox x:Name="FrameRateSelector" HorizontalAlignment="Stretch" SelectedIndex="1">
                            <ComboBoxItem Content="On Ones (24 fps)" Tag="24"/>
                            <ComboBoxItem Content="On Twos (12 fps — Standard)" Tag="12"/>
                            <ComboBoxItem Content="On Threes (8 fps)" Tag="8"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6">
                        <TextBlock Text="Full Animation" FontSize="14" FontWeight="SemiBold"/>
                        <ToggleSwitch x:Name="InterpolationToggle" IsOn="False"
                                      OnContent="On Ones (Sakuga)" OffContent="Stepped (Standard)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6">
                        <TextBlock Text="Impact Frames" FontSize="14"/>
                        <ToggleSwitch IsOn="True" OnContent="Enabled" OffContent="Disabled"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6">
                        <TextBlock Text="Smear Frames" FontSize="14"/>
                        <ToggleSwitch IsOn="True" OnContent="Enabled" OffContent="Disabled"/>
                    </StackPanel>
                </Grid>

                <!-- Generate -->
                <Button x:Name="BtnGenerateAnimation" Content="🎬 Generate Animation"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnGenerateAnimation_Click"/>
                <TextBox x:Name="AnimationStatus" IsReadOnly="True" AcceptsReturn="True"
                         MinHeight="150" TextWrapping="Wrap" PlaceholderText="Animation script output appears here"/>

                <!-- Lock Phase -->
                <InfoBar x:Name="PhaseInfoBar" IsOpen="False" IsClosable="True"
                         Severity="Success" Title="Animation Complete"
                         Message="Proceed to Phase 4: Satsuei (Compositing)."/>
                <Button x:Name="BtnLockAnimation" Content="🔒 Lock Animation &amp; Proceed →"
                        Click="BtnLockAnimation_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
