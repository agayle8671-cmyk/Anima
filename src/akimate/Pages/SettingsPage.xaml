<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="akimate.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32,40,40">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="32" FontWeight="Bold"/>

            <!-- Inference Mode -->
            <StackPanel Spacing="8">
                <TextBlock Text="AI Inference Mode" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Choose whether to run AI models locally on your GPU or via cloud APIs."
                           FontSize="13" Opacity="0.6" TextWrapping="Wrap"/>
                <RadioButtons x:Name="InferenceModeSelector" SelectedIndex="0"
                              SelectionChanged="InferenceMode_Changed">
                    <RadioButton Content="Local GPU (ONNX Runtime + DirectML / TensorRT)" Tag="local"/>
                    <RadioButton Content="Cloud API (Runway Gen-3 Alpha)" Tag="cloud"/>
                </RadioButtons>
            </StackPanel>

            <!-- API Keys -->
            <StackPanel Spacing="8">
                <TextBlock Text="API Keys" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="API keys are stored securely using Windows Credential Manager and never saved in project files."
                           FontSize="13" Opacity="0.6" TextWrapping="Wrap"/>

                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <PasswordBox x:Name="RunwayKeyBox" Grid.Column="0" Grid.Row="0"
                                 Header="Runway Gen-3 Alpha API Key"
                                 PlaceholderText="Enter your Runway API key"/>
                    <Button Grid.Column="1" Grid.Row="0" Content="Save"
                            VerticalAlignment="Bottom" Click="BtnSaveRunwayKey_Click"/>

                    <PasswordBox x:Name="SoraKeyBox" Grid.Column="0" Grid.Row="1"
                                 Header="OpenAI Sora 2 API Key"
                                 PlaceholderText="Enter your Sora 2 API key"/>
                    <Button Grid.Column="1" Grid.Row="1" Content="Save"
                            VerticalAlignment="Bottom" Click="BtnSaveSoraKey_Click"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="BtnClearKeys" Content="🗑 Clear All Stored Keys"
                            Click="BtnClearKeys_Click"/>
                    <TextBlock x:Name="KeyStatusText" VerticalAlignment="Center"
                               Opacity="0.7" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <!-- Blender Path -->
            <StackPanel Spacing="8">
                <TextBlock Text="Blender Installation" FontSize="18" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BlenderPathBox" Header="Blender Executable Path"
                             IsReadOnly="True" PlaceholderText="Auto-detected or browse..."/>
                    <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom"
                            Click="BtnBrowseBlender_Click"/>
                </Grid>
                <InfoBar x:Name="BlenderStatusInfo" IsOpen="False" IsClosable="False"
                         Severity="Success" Title="Blender Detected"/>
            </StackPanel>

            <!-- About -->
            <StackPanel Spacing="8">
                <TextBlock Text="About" FontSize="18" FontWeight="SemiBold"/>
                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      CornerRadius="8" Padding="20" BorderThickness="1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="akimate v0.1.0" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="AI-Assisted Anime Production Studio" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="© 2026 Andre Gayle. All rights reserved." FontSize="12" Opacity="0.5"/>
                        <TextBlock Text="Blender® is a registered trademark of the Blender Foundation." 
                                   FontSize="11" Opacity="0.4" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
