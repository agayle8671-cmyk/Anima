<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="akimate.Pages.CompositorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Gate Overlay -->
        <StackPanel x:Name="GateOverlay" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE72E;" FontSize="48" Opacity="0.4"/>
            <TextBlock Text="Phase Locked" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Complete Phase 3 (Animatic &amp; Genga) first." Opacity="0.6" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer x:Name="ContentPanel" VerticalScrollBarVisibility="Auto" Padding="40,32,40,40" Visibility="Collapsed">
            <StackPanel Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

                <StackPanel Spacing="4">
                    <TextBlock Text="Phase 4: Satsuei (Compositing)" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Multi-pass rendering, compositing, color grading, atmospheric effects, and final export."
                               FontSize="14" Opacity="0.7" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Compositing Controls -->
                <TextBlock Text="Compositing Effects" FontSize="18" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="16" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6">
                        <TextBlock Text="Depth of Field" FontSize="14"/>
                        <ToggleSwitch x:Name="ToggleDOF" IsOn="True" OnContent="On" OffContent="Off"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="6">
                        <TextBlock Text="Volumetric Fog" FontSize="14"/>
                        <ToggleSwitch x:Name="ToggleFog" IsOn="False" OnContent="On" OffContent="Off"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="6">
                        <TextBlock Text="Color Grading" FontSize="14"/>
                        <ToggleSwitch x:Name="ToggleColorGrading" IsOn="True" OnContent="On" OffContent="Off"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="6">
                        <TextBlock Text="Bloom / Glow" FontSize="14"/>
                        <ToggleSwitch IsOn="True" OnContent="On" OffContent="Off"/>
                    </StackPanel>
                </Grid>

                <!-- Export -->
                <TextBlock Text="Export" FontSize="18" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnExportVideo" Content="🎬 Export Video (MP4)"
                            HorizontalAlignment="Stretch" Height="48"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnExportVideo_Click"/>
                    <Button x:Name="BtnExportBlend" Grid.Column="1"
                            Content="💾 Export Blender Project (.blend)"
                            HorizontalAlignment="Stretch" Height="48"
                            Click="BtnExportBlend_Click"/>
                </Grid>
                <TextBlock x:Name="ExportStatus" TextWrapping="Wrap" Opacity="0.7" FontSize="13"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
